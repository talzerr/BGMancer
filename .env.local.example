# NextAuth
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:6959

# Google OAuth (required in production — "Sign in with Google")
# Not needed for local dev — a Credentials provider is used instead.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# YouTube Data API v3 (https://console.cloud.google.com → APIs & Services → YouTube Data API v3)
YOUTUBE_API_KEY=

# Steam Web API (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# Discogs API (https://www.discogs.com/settings/developers → "Generate new token")
# Recommended — without it, rate limit is 25 req/min and Cloudflare IPs get throttled
# DISCOGS_TOKEN=

# Anthropic Claude (required — https://console.anthropic.com)
ANTHROPIC_API_KEY=
