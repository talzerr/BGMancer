# NextAuth
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:6959

# Google OAuth (console.cloud.google.com) — only needed for "Sync to YouTube"
# Enable: Google Identity, YouTube Data API v3
# Authorized redirect URIs: http://localhost:6959/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MySQL (local)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=bgmancer

# YouTube Data API v3 (console.cloud.google.com → Credentials → API Key)
# Restrict to YouTube Data API v3 only
YOUTUBE_API_KEY=

# Ollama (local LLM — https://ollama.com)
# Run: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
