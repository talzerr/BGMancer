# NextAuth
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:6959

# Google OAuth (optional — only needed for YouTube playlist sync)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# SQLite database path (optional — defaults to bgmancer.db in the project root)
# SQLITE_PATH=/path/to/bgmancer.db

# YouTube Data API v3 (https://console.cloud.google.com → APIs & Services → YouTube Data API v3)
YOUTUBE_API_KEY=

# Steam Web API (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# Discogs API (https://www.discogs.com/settings/developers — personal access token)
# Optional — if absent, unauthenticated requests are used (lower rate limit: 25 req/min)
# DISCOGS_TOKEN=

# LLM — provide at least one of the following:

# Anthropic Claude (hosted — https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Ollama (local — https://ollama.com — run: ollama pull llama3.2)
# Used for Phase 2 candidate selection when set; falls back to Anthropic if unset.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
