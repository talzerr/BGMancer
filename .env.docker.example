# ─────────────────────────────────────────────────────────────────────────────
# BGMancer — Docker environment
# Copy this file to .env.docker and fill in your keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# YouTube Data API v3
# How to get one (free):
#   1. Go to https://console.cloud.google.com
#   2. Create a project (any name)
#   3. Click "APIs & Services" → "Enable APIs" → search "YouTube Data API v3" → Enable
#   4. Click "Credentials" → "Create Credentials" → "API Key"
#   5. Copy the key below
YOUTUBE_API_KEY=

# Steam Web API (used for importing your Steam game library)
# How to get one (free, instant):
#   1. Go to https://steamcommunity.com/dev/apikey
#   2. Log in and fill in the form (domain: localhost)
#   3. Copy the key below
STEAM_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# A secret used to secure login sessions.
# Leave blank — one is auto-generated when the container starts.
# Only set this if you want sessions to survive container restarts.
NEXTAUTH_SECRET=

# Google OAuth — only needed for "Sync to YouTube" (push playlist to your account).
# Leave both blank if you don't need that feature.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backstage admin secret (protects /backstage routes)
# Generate one with: openssl rand -base64 32
# ADMIN_SECRET=
